# .gitattributes — Normalize line endings across Windows/macOS/Linux contributors

# Default: normalize to LF in the repo; convert to CRLF on Windows checkout
* text=auto eol=lf

# Python source files — always LF
*.py    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf

# TypeScript / JavaScript — always LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf

# Web / config — always LF
*.html  text eol=lf
*.css   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.env*  text eol=lf

# Binary files — never modify line endings
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.eot   binary
*.ttf   binary
*.otf   binary
