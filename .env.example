# ============================================================
# FIFA World Cup 2026 — Crowd Navigation System
# Environment Variables Template
# NEVER commit the actual .env file to version control.
# ============================================================

# ─── Application ────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_DEBUG=false
APP_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── JWT (RS256 — generate with: openssl genrsa -out private.pem 2048) ─
# Store as base64-encoded strings:
# cat private.pem | base64 -w 0
JWT_PRIVATE_KEY_B64=CHANGE_ME_base64_encoded_rsa_private_key
JWT_PUBLIC_KEY_B64=CHANGE_ME_base64_encoded_rsa_public_key
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=fifauser
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=fifacrowdnav
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_DB=0
REDIS_CROWD_CACHE_TTL=30          # seconds — live crowd density
REDIS_ROUTE_CACHE_TTL=3600        # seconds — static route segments
REDIS_GENAI_CACHE_TTL=300         # seconds — GenAI translation cache

# ─── Google Gemini / GenAI ───────────────────────────────────
GEMINI_API_KEY=CHANGE_ME_your_google_gemini_api_key
GEMINI_MODEL=gemini-1.5-pro
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_TEMPERATURE=0.3            # low temperature for factual navigation

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute     # per IP for standard endpoints
RATE_LIMIT_GENAI=10/minute        # stricter limit for GenAI endpoints
RATE_LIMIT_AUTH=5/minute          # brute-force protection on /auth

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://your-production-domain.com

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                   # json | text

# ─── Feature Flags ──────────────────────────────────────────
ENABLE_GENAI=true                 # false → use static fallback routing
ENABLE_WEBSOCKETS=true
